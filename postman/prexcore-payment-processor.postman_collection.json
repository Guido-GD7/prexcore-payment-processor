{
  "info": {
    "name": "PrexCORE Payment Processor",
    "description": "Postman collection for testing the PrexCORE Payment Processor API. Includes happy paths and edge cases: duplicate clients, missing clients, invalid amounts, overdraft validation, balance lookup, and balance persistence.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "client_id_1",
      "value": "1",
      "type": "string"
    },
    {
      "key": "client_id_2",
      "value": "2",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health / Basic",
      "item": [
        {
          "name": "Store balances with no clients - should fail",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/store_balances",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "store_balances"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 or 500 depending on implementation', function () {",
                  "    pm.expect([400, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Response has error code and message', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('code');",
                  "    pm.expect(json).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
